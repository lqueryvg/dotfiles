# ~/.zshrc — managed by chezmoi

# Legacy sourcing — remove when ~/dotfiles/ is fully migrated
[[ -f "${HOME}/dotfiles/my_zshrc.sh" ]] && source "${HOME}/dotfiles/my_zshrc.sh"

# Source all scripts in ~/.config/dotfile_source/ (maxdepth 2 picks up third-party/)
while read -r _dotfile_source_file; do
    source "${_dotfile_source_file}"
done < <(
    find "${HOME}/.config/dotfile_source" \
        -maxdepth 2 \
        -type f \
        \( -name '*.zsh' -o -name '*.sh' \) \
    | sort
)
unset _dotfile_source_file

# Machine-specific overrides (gitignored, never committed)
if [[ -d "${HOME}/private.d" ]]; then
    while read -r _dotfile_source_file; do
        source "${_dotfile_source_file}"
    done < <(find "${HOME}/private.d" -maxdepth 1 -type f -name '*.sh' | sort)
    unset _dotfile_source_file
fi

# Final escape hatch for anything that shouldn't be in the repo
if [[ -f "${HOME}/.dotfiles.local" ]]; then source "${HOME}/.dotfiles.local"; fi
