#!/usr/bin/env bash
{{ template "script_utils.bash" . }}
# tool-versions hash: {{ include "dot_tool-versions.tmpl" | sha256sum }}
set -euo pipefail

{{ if not .is_ci_workflow -}}
MISE="${HOME}/.local/bin/mise"
if ! command -v mise &>/dev/null && [[ ! -x "$MISE" ]]; then
  log_warn "mise not found, skipping tool installation"
  exit 0
fi

MISE="$(command -v mise 2>/dev/null || echo "${HOME}/.local/bin/mise")"
log_info "Installing mise tools..."
if "$MISE" install --quiet; then
  log_success "mise tools installed"
else
  log_warn "Some mise tools failed to install — run 'mise install' manually to see details"
fi
{{ else -}}
log_info "Skipping mise tool installation (CI)"
{{ end -}}
