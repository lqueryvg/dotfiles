#!/usr/bin/env bash
{{ template "script_utils.bash" . }}
set -euo pipefail

{{ if not .is_ci_workflow -}}
export GIT_TERMINAL_PROMPT=0  # fail fast rather than prompting for credentials
VUNDLE_DIR="${HOME}/.vim/bundle/Vundle.vim"

if [[ -f "${VUNDLE_DIR}/autoload/vundle.vim" ]]; then
  log_info "Vundle already installed, skipping"
else
  log_info "Installing Vundle..."
  rm -rf "${VUNDLE_DIR}"
  [[ -L "${HOME}/.vim" ]] && mv "${HOME}/.vim" "${HOME}/.vim.bak-$(date +%Y%m%d%H%M%S)"
  mkdir -p "$(dirname "${VUNDLE_DIR}")"
  git clone https://github.com/VundleVim/Vundle.vim.git "${VUNDLE_DIR}"
fi

log_info "Installing vim plugins..."
vim -T dumb --not-a-term +PluginInstall +qall >/dev/null 2>&1; echo
log_success "Vim plugins installed"
{{ else -}}
log_info "Skipping vim plugins (CI)"
{{ end -}}
