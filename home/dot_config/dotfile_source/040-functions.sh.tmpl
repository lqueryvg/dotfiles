command_exists() {
  command -v "$1" > /dev/null 2>&1
}

source_if_exists() {
  for f in "$@"; do
    [[ -f "$f" ]] && source "$f"
  done
}

# Set terminal window title
title() {
  echo -ne "\033]0;${1}\007"
}

# "source it" — quick way to source a dotfile_source script by basename
sit() {
  local d="${HOME}/.config/dotfile_source"
  for f in "${d}/${1}" "${d}/${1}.sh" "${d}/third-party/${1}" "${d}/third-party/${1}.sh"; do
    if [[ -f "$f" ]]; then
      source "$f"
      return
    fi
  done
  echo "sit: not found: $1"
}

blue()   { echo "\e[0;34m${1}\e[0m" }
red()    { echo "\e[0;31m${1}\e[0m" }
yellow() { echo "\e[0;33m${1}\e[0m" }
lilac()  { echo "\e[0;36m${1}\e[0m" }
