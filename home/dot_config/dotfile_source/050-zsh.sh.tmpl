unset zle_bracketed_paste   # paste executes immediately (no bracketed-paste wrapper)

export SHELL=/bin/zsh
HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
setopt inc_append_history
setopt interactivecomments
setopt auto_cd
setopt autopushd

bindkey -v  # vi key bindings

# Arrow key bindings
bindkey "^[[C" forward-word         # right arrow → forward word

# NOTE: compinit and menuselect bindings are handled by the legacy system during
# dual-sourcing. Re-add here when ~/dotfiles/my_zshrc.sh dual-sourcing is removed.
